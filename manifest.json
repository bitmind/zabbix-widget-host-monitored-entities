{
	"manifest_version": 2.0,
	"id": "hostitemsstate",
	"type": "widget",
	"name": "Host monitoring entities",
	"namespace": "HostItemsState",
	"version": "1.0",
	"description": "Displays the item count by state (Normal, Not supported, Disabled) for a given host.",
	"widget": {
		"js_class": "CWidgetHostItemsState",
		"in": {
			"hostid": {
				"type": "_hostid"
			}
		},
		"size": {
			"width": 12,
			"height": 5
		},
		"refresh_rate": 900
	},
	"actions": {
		"widget.hostitemsstate.view": {
			"class": "WidgetView"
		}
	},
	"assets": {
		"js": ["class.widget.js"]
	}
}
